assification\",\n    name=\"AST-synthetic-TTA\",\n    config={\n        \"architecture\": \"AST-pretrained\",\n        \"epochs\": 5,\n        \"batch_size\": 8,\n        \"learning_rate\": 2e-5\n    }\n)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Final AST Training Loop","metadata":{}},{"cell_type":"code","source":"start_time = time.time()\n\nbest_f1 = 0\n\nfor epoch in range(EPOCHS):\n\n    model.train()\n\n    running_loss = 0\n\n    for batch in tqdm(train_loader):\n\n        inputs = batch[\"input_values\"].to(device)\n        labels = batch[\"labels\"].to(device)\n\n        outputs = model(inputs)\n\n        logits = outputs.logits\n\n        loss = criterion(logits, labels)\n\n        optimizer.zero_grad()\n        loss.backward()\n        optimizer.step()\n\n        running_loss += loss.item()\n\n    train_loss = running_loss / len(train_loader)\n\n    val_f1 = evaluate(model, val_loader)\n\n    print(f\"\\nEpoch {epoch+1}/{EPOCHS}\")\n    print(\"Train Loss:\", train_loss)\n    print(\"Validation Macro F1:\", val_f1)\n\n    wandb.log({         \n        \"train_loss\": train_loss,\n        \"val_macro_f1\": val_f1\n    })\n\n    if val_f1 > best_f1:\n\n        best_f1 = val_f1\n        torch.save(model.state_dict(), \"/kaggle/working/best_ast_mashup_model.pth\")\n        print(\"Best model saved!\")\n\n#calculates training time\nend_time = time.time()\ntotal_time = end_time - start_time\nprint(f\"Total Training Time: {total_time/60:.2f} minutes\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T15:20:43.937432Z","iopub.execute_input":"2026-03-19T15:20:43.938270Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"wandb.finish()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Inference","metadata":{}},{"cell_type":"markdown","source":"### Define Test Data Path","metadata":{}},{"cell_type":"code","source":"DATA_ROOT = \"/kaggle/input/jan-2026-dl-gen-ai-project/messy_mashup\"\n\nTEST_PATH = os.path.join(DATA_ROOT, \"mashups\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Label Map for Inference","metadata":{}},{"cell_type":"code","source":"label_map = {\n    \"blues\":0,\n    \"classical\":1,\n    \"country\":2,\n    \"disco\":3,\n    \"hiphop\":4,\n    \"jazz\":5,\n    \"metal\":6,\n    \"pop\":7,\n    \"reggae\":8,\n    \"rock\":9\n}\n\nid2label = {v:k for k,v in label_map.items()}","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Reload Feature Extractor","metadata":{}},{"cell_type":"code","source":"feature_extractor = ASTFeatureExtractor.from_pretrained(\n    \"MIT/ast-finetuned-audioset-10-10-0.4593\"\n)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Load Best Saved Model","metadata":{}},{"cell_type":"code","source":"MODEL_PATH = \"/kaggle/working/best_ast_mashup_model.pth\"\n\nmodel = ASTForAudioClassification.from_pretrained(\n    \"MIT/ast-finetuned-audioset-10-10-0.4593\",\n    num_labels=10,\n    ignore_mismatched_sizes=True\n)\n\nmodel.load_state_dict(torch.load(MODEL_PATH, map_location=device))\n\nmodel = model.to(device)\nmodel.eval()\n\nprint(\"Model loaded successfully\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### predict_audio() with TTA","metadata":{}},{"cell_type":"code","source":"def predict_audio(audio_path, n_crops=16):\n\n    audio, sr = librosa.load(audio_path, sr=16000)\n\n    crop_len = 10 * sr\n\n    if len(audio) < crop_len:\n        audio = np.pad(audio, (0, crop_len - len(audio)))\n\n    step = max((len(audio) - crop_len) // (n_crops - 1), 1)\n\n    weighted_logits = None\n    total_conf = 0.0\n\n    for i in range(n_crops):\n\n        start = i * step\n        segment = audio[start:start + crop_len]\n\n        segment = segment / (np.max(np.abs(segment)) + 1e-6)\n\n        inputs = feature_extractor(\n            segment,\n            sampling_rate=16000,\n            return_tensors=\"pt\"\n        )\n\n        input_values = inputs[\"input_values\"].to(device)\n\n        with torch.no_grad():\n            outputs = model(input_values)\n\n        logits = outputs.logits.squeeze(0).cpu()\n\n        probs = torch.softmax(logits, dim=0)\n\n        conf = torch.max(probs).item()\n\n        if weighted_logits is None:\n            weighted_logits = logits * conf\n        else:\n            weighted_logits += logits * conf\n\n        total_conf += conf\n\n    final_logits = weighted_logits / total_conf\n\n    pred = torch.argmax(final_logits).item()\n\n    return pred","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Load Test CSV","metadata":{}},{"cell_type":"code","source":"test_df = pd.read_csv(os.path.join(DATA_ROOT, \"test.csv\"))\n\nprint(\"Total mashups:\", len(test_df))","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Run Predictions on All Test Files","metadata":{}},{"cell_type":"code","source":"predictions = []\n\nfor _, row in tqdm(test_df.iterrows(), total=len(test_df)):\n\n    audio_path = os.path.join(DATA_ROOT, row[\"filename\"])\n\n    pred_id = predict_audio(audio_path)\n\n    pred_label = id2label[pred_id]\n\n    predictions.append(pred_label)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Model Summary — AST with Synthetic Mashup Training + TTA\n\n| Item | Detail |\n|------|--------|\n| **Model** | Audio Spectrogram Transformer (AST) pretrained on AudioSet |\n| **Training Data** | 3000 synthetic mashups (300/genre × 10 genres) + ESC-50 noise augmentation |\n| **Optimizer** | AdamW, lr=2e-5 |\n| **Epochs** | 5 |\n| **Val F1 (Epoch 1)** | 0.912690 |\n| **Val F1 (Epoch 2)** | 0.894973 |\n| **Val 