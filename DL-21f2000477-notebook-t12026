ro_f1: ~0.8249\n### Validation macro_f1: ~0.60805\n\n\n### Decision: Try CRNN to capture temporal patterns better.\nThe CNN model was trained using Mel Spectrogram representations of audio samples.","metadata":{}},{"cell_type":"markdown","source":"## CRNN ","metadata":{}},{"cell_type":"markdown","source":"### CRNN Architecture","metadata":{}},{"cell_type":"code","source":"class CRNN(nn.Module):\n\n    def __init__(self):\n        super().__init__()\n\n        # CNN feature extractor\n        self.conv1 = nn.Conv2d(1, 32, kernel_size=3, padding=1)\n        self.bn1 = nn.BatchNorm2d(32)\n\n        self.conv2 = nn.Conv2d(32, 64, kernel_size=3, padding=1)\n        self.bn2 = nn.BatchNorm2d(64)\n\n        self.conv3 = nn.Conv2d(64, 128, kernel_size=3, padding=1)\n        self.bn3 = nn.BatchNorm2d(128)\n\n        self.pool = nn.MaxPool2d(2, 2)\n        self.dropout = nn.Dropout(0.3)\n\n        # LSTM\n        self.lstm = nn.LSTM(\n            input_size=128,\n            hidden_size=128,\n            num_layers=2,\n            batch_first=True,\n            bidirectional=True,\n            dropout=0.3   \n        )\n\n        # classifier\n        self.fc = nn.Linear(256, 10)\n\n    def forward(self, x):\n        x = self.pool(F.relu(self.bn1(self.conv1(x))))\n        x = self.pool(F.relu(self.bn2(self.conv2(x))))\n        x = self.pool(F.relu(self.bn3(self.conv3(x))))\n\n        # shape (B,128,H,W)\n        x = x.mean(dim=2)\n\n        # (B,128,time) → (B,time,128)\n        x = x.permute(0, 2, 1)\n\n        x, _ = self.lstm(x)\n\n        # better than last timestep\n        x = x.mean(dim=1)\n\n        x = self.dropout(x)\n        x = self.fc(x)\n\n        return x","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-25T08:55:33.405042Z","iopub.execute_input":"2026-03-25T08:55:33.405878Z","iopub.status.idle":"2026-03-25T08:55:33.413445Z","shell.execute_reply.started":"2026-03-25T08:55:33.405845Z","shell.execute_reply":"2026-03-25T08:55:33.412548Z"}},"out