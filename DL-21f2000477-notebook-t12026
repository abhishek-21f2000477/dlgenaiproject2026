(x))))\n        x = self.pool(F.relu(self.bn3(self.conv3(x))))\n\n        # shape (B,128,H,W)\n        x = x.mean(dim=2)\n\n        # (B,128,time) → (B,time,128)\n        x = x.permute(0, 2, 1)\n\n        x, _ = self.lstm(x)\n\n        # better than last timestep\n        x = x.mean(dim=1)\n\n        x = self.dropout(x)\n        x = self.fc(x)\n\n        return x","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Instantiate CRNN","metadata":{}},{"cell_type":"code","source":"# improved_crnn = ImprovedCRNN().to(device)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-06T18:37:56.499929Z","iopub.execute_input":"2026-03-06T18:37:56.500666Z","iopub.status.idle":"2026-03-06T18:37:56.516829Z","shell.execute_reply.started":"2026-03-06T18:37:56.500639Z","shell.execute_reply":"2026-03-06T18:37:56.516073Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"crnn_model = CRNN().to(device)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### CRNN Optimizer","metadata":{}},{"cell_type":"code","source":"# optimizer = torch.optim.Adam(improved_crnn.parameters(), lr=0.001)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-06T18:38:11.094932Z","iopub.execute_input":"2026-03-06T18:38:11.095711Z","iopub.status.idle":"2026-03-06T18:38:11.100486Z","shell.execute_reply.started":"2026-03-06T18:38:11.095682Z","shell.execute_reply":"2026-03-06T18:38:11.099922Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"optimizer = torch.optim.Adam(crnn_model.parameters(), lr=0.001, weight_decay=1e-5)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### CRNN Training Loop","metadata":{}},{"cell_type":"code","source":"wandb.init(\n    project=\"messy-mashup-genre-classification\",\n    name=\"CRNN\",\n    config={\n        \"architecture\": \"CRNN\",\n        \"epochs\": 10