rusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### predict_audio() with TTA","metadata":{}},{"cell_type":"code","source":"def predict_audio(audio_path, n_crops=16):\n\n    audio, sr = librosa.load(audio_path, sr=16000)\n\n    crop_len = 10 * sr\n\n    if len(audio) < crop_len:\n        audio = np.pad(audio, (0, crop_len - len(audio)))\n\n    step = max((len(audio) - crop_len) // (n_crops - 1), 1)\n\n    weighted_logits = None\n    total_conf = 0.0\n\n    for i in range(n_crops):\n\n        start = i * step\n        segment = audio[start:start + crop_len]\n\n        segment = segment / (np.max(np.abs(segment)) + 1e-6)\n\n        inputs = feature_extractor(\n            segment,\n            sampling_rate=16000,\n            return_tensors=\"pt\"\n        )\n\n        input_values = inputs[\"input_values\"].to(device)\n\n        with torch.no_grad():\n            outputs = model(input_values)\n\n        logits = outputs.logits.squeeze(0).cpu()\n\n        probs = torch.softmax(logits, dim=0)\n\n        conf = torch.max(probs).item()\n\n        if weighted_logits is None:\n            weighted_logits = logits * conf\n        else:\n            weighted_logits += logits * conf\n\n        total_conf += conf\n\n    final_logits = weighted_logits / total_conf\n\n    pred = torch.argmax(final_logits).item()\n\n    return pred","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Load Test CSV","metadata":{}},{"cell_type":"code","source":"test_df = pd.read_csv(os.path.join(DATA_ROOT, \"test.csv\"))\n\nprint(\"Total mashups:\", len(test_df))","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Run Predictions on All Test Files","metadata":{}},{"cell_type":"code","source":"predictions = []\n\nfor _, row in tqdm(test_df.iterrows(), total=len(test_df)):\n\n    audio_path = os.path.join(DATA_ROOT, row[\"filename\"])\n\n    pred_id = predict_aud