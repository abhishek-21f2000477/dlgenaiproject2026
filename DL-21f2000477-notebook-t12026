ata":{}},{"cell_type":"code","source":"class CNNModel(nn.Module):\n    \n    def __init__(self):\n        super().__init__()\n        \n        self.conv1 = nn.Conv2d(1, 16, kernel_size=3, padding=1)        \n        self.conv2 = nn.Conv2d(16, 32, kernel_size=3, padding=1)\n        self.pool = nn.MaxPool2d(2,2)\n        \n        # Adaptive pooling ensures fixed feature size\n        self.adaptive_pool = nn.AdaptiveAvgPool2d((8,8))        \n        self.fc1 = nn.Linear(32*8*8, 128)        \n        self.fc2 = nn.Linear(128, 10)\n        \n        \n    def forward(self, x):        \n        x = self.pool(F.relu(self.conv1(x)))        \n        x = self.pool(F.relu(self.conv2(x)))        \n        x = self.adaptive_pool(x)\n        \n        x = torch.flatten(x, start_dim=1)        \n        x = F.relu(self.fc1(x))        \n        x = self.fc2(x)\n        \n        return x","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-06T17:50:11.007141Z","iopub.execute_input":"2026-03-06T17:50:11.007499Z","iopub.status.idle":"2026-03-06T17:50:11.016039Z","shell.execute_reply.started":"2026-03-06T17:50:11.007470Z","shell.execute_reply":"2026-03-06T17:50:11.015064Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Loss and Optimizer Setup","metadata":{}},{"cell_type":"code","source":"# sample_batch, _ = next(iter(train_loader))\n\n# output = model(sample_batch)\n\n# print(\"Output shape:\", output.shape)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-06T16:35:20.193041Z","iopub.status.idle":"2026-03-06T16:35:20.193379Z","shell.execute_reply.started":"2026-03-06T16:35:20.193221Z","shell.execute_reply":"2026-03-06T16:35:20.193240Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"\n# Loss\n\ncriterion = nn.CrossEntropyLoss()\n\n# Optimizer\n\noptimizer = optim.Adam(model.parameters(), lr=0.001)\n\nprint(\"Setup complete\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03