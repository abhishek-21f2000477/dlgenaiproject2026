ir(genre_dir)\n\n    stems = [\"drums.wav\",\"bass.wav\",\"vocals.wav\",\"other.wav\"]\n\n    tracks = []\n\n    for stem in stems:\n\n        song = random.choice(songs)\n\n        path = os.path.join(genre_dir, song, stem)\n\n        audio, sr = librosa.load(path, sr=TARGET_SR)\n\n        tracks.append(audio)\n\n    min_len = min(len(t) for t in tracks)\n\n    tracks = [t[:min_len] for t in tracks]\n\n    mashup = np.sum(tracks, axis=0)\n\n    mashup = mashup / (np.max(np.abs(mashup)) + 1e-6)\n\n    return mashup","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T15:02:18.735759Z","iopub.execute_input":"2026-03-19T15:02:18.736494Z","iopub.status.idle":"2026-03-19T15:02:18.741728Z","shell.execute_reply.started":"2026-03-19T15:02:18.736468Z","shell.execute_reply":"2026-03-19T15:02:18.741129Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Generate 300 Mashups Per Genre","metadata":{}},{"cell_type":"code","source":"metadata = []\n\nfor genre in tqdm(genres):\n\n    genre_dir = os.path.join(GENRES_PATH, genre)\n\n    out_dir = os.path.join(OUTPUT_DIR, genre)\n    os.makedirs(out_dir, exist_ok=True)\n\n    for i in range(300):\n\n        mashup = create_synthetic_mashup(genre_dir)\n\n        save_path = os.path.join(out_dir, f\"{genre}_mashup_{i}.wav\")\n\n        sf.write(save_path, mashup, TARGET_SR)\n\n        metadata.append({\n            \"filepath\": save_path,\n            \"genre\": genre\n        })","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T15:02:35.915888Z","iopub.execute_input":"2026-03-19T15:02:35.916376Z","iopub.status.idle":"2026-03-19T15:16:22.854327Z","shell.execute_reply.started":"2026-03-19T15:02:35.916347Z","shell.execute_reply":"2026-03-19T15:16:22.853590Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Save Metadata CSV","metadata":{}},{"cell_type":"code","source":"metadata_df = pd.DataFrame(metadata)\n\nmetadata_df.to_csv(\"/kaggle/wor