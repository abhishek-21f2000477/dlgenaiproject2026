max)\n\n    return mel_db\n\n\nprint(\"Creating Mel Spectrograms...\")\n\n\nfor genre in os.listdir(INPUT_DIR):\n\n    genre_path = os.path.join(INPUT_DIR, genre)\n\n    if not os.path.isdir(genre_path):\n\n        continue\n\n\n    os.makedirs(os.path.join(OUTPUT_DIR, genre), exist_ok=True)\n\n\n    for file in tqdm(os.listdir(genre_path)):\n\n        file_path = os.path.join(genre_path, file)\n\n        mel = create_mel(file_path)\n\n        np.save(\n\n            os.path.join(\n\n                OUTPUT_DIR,\n                genre,\n                file.replace(\".wav\", \".npy\")\n\n            ),\n\n            mel\n\n        )\n\n\nprint(\"DONE\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-06T16:37:05.973690Z","iopub.execute_input":"2026-03-06T16:37:05.974341Z","iopub.status.idle":"2026-03-06T16:38:09.298965Z","shell.execute_reply.started":"2026-03-06T16:37:05.974311Z","shell.execute_reply":"2026-03-06T16:38:09.297929Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### MelDataset Class\n","metadata":{}},{"cell_type":"code","source":"# Path\nDATA_DIR = \"/kaggle/working/mel_spectrograms\"\n\n# Genre list\nGENRES = sorted(os.listdir(DATA_DIR))\n\n# Create label mapping\nlabel_map = {\n    genre: idx\n    \n    for idx, genre in enumerate(GENRES)\n}\nprint(label_map)\n\nclass MelDataset(Dataset):\n    def __init__(self, data_dir):\n        self.data = []\n        for genre in GENRES:\n            genre_path = os.path.join(data_dir, genre)\n            \n            for file in os.listdir(genre_path):    \n                self.data.append(\n                    (\n                        os.path.join(genre_path, file),\n                        label_map[genre]\n                    )\n                )\n    \n    def __len__(self):\n        return len(self.data)\n    \n    \n    def __getitem__(self, idx):\n        file_path, label = self.data[idx]\n        mel = np.load(file_path)\n        \n        # Convert to