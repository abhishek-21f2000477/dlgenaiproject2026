    "class ASTDataset(Dataset):\n",
    "\n",
    "    def __init__(self, dataframe, feature_extractor, audio_cache, noise_files=None, augment=False):\n",
    "\n",
    "        self.df = dataframe.reset_index(drop=True)\n",
    "        self.feature_extractor = feature_extractor\n",
    "        self.audio_cache = audio_cache\n",
    "        self.noise_files = noise_files\n",
    "        self.augment = augment\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.df)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "\n",
    "        row = self.df.iloc[idx]\n",
    "\n",
    "        audio = self.audio_cache[row[\"filepath\"]]\n",
    "        label = row[\"label\"]\n",
    "\n",
    "        crop_len = 10 * 16000\n",
    "\n",
    "        if len(audio) < crop_len:\n",
    "            audio = np.pad(audio, (0, crop_len - len(audio)))\n",
    "\n",
    "        start = np.random.randint(0, len(audio) - crop_len + 1)\n",
    "        segment = audio[start:start + crop_len]\n",
    "\n",
    "        if self.augment:\n",
    "            segment = add_noise(segment, self.noise_files)\n",
    "\n",
    "        inputs = self.feature_extractor(\n",
    "            segment,\n",
    "            sampling_rate=16000,\n",
    "            return_tensors=\"pt\"\n",
    "        )\n",
    "\n",
    "        return {\n",
    "            \"input_values\": inputs[\"input_values\"].squeeze(0),\n",
    "            \"labels\": torch.tensor(label).long()\n",
    "        }"
   ]
  },
