nn_f1 = val_f1\n        torch.save(crnn_model.state_dict(), \"best_crnn_model.pth\")\n\n\n    # PRINT RESULTS\n    print(f\"Epoch {epoch+1}/{EPOCHS}\")\n    print(f\"Train Loss: {train_loss:.4f} | Train F1: {train_f1:.4f}\")\n    print(f\"Val Loss: {val_loss:.4f} | Val F1: {val_f1:.4f}\")\n    print(\"Best CRNN Val F1:\", best_crnn_f1)\n\n    wandb.log({\n    \"train_loss\": train_loss,\n    \"val_loss\": val_loss,\n    \"train_macro_f1\": train_f1,\n    \"val_macro_f1\": val_f1\n})\n    print(\"--------------------------------------\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"wandb.finish()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# AST","metadata":{}},{"cell_type":"markdown","source":"## Loading ESC-50 Noise Dataset\n\nTo reduce the distribution shift between clean training songs and noisy mashup test audio, environmental noise samples from the ESC-50 dataset are used for data augmentation.","metadata":{}},{"cell_type":"code","source":"# ESC-50 noise path\nESC50_PATH = \"/kaggle/input/jan-2026-dl-gen-ai-project/messy_mashup/ESC-50-master/audio\"\n\n# collect all noise files\nnoise_files = glob.glob(os.path.join(ESC50_PATH, \"*.wav\"))\n\nprint(\"Total ESC-50 noise files:\", len(noise_files))\n\n# show some samples\nnoise_files[:5]","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-06T18:43:28.344303Z","iopub.execute_input":"2026-03-06T18:43:28.344988Z","iopub.status.idle":"2026-03-06T18:43:28.366738Z","shell.execute_reply.started":"2026-03-06T18:43:28.344959Z","shell.execute_reply":"2026-03-06T18:43:28.365986Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"###  Inspect a Noise Sample","metadata":{}},{"cell_type":"code","source":"noise_sample = noise_files[0]\n\nnoise_audio, sr = librosa.load(noise_sample, sr=16000)\n\nprint(\"Noise length:\", len(noise_audio))\nprint(\"Sample rate:\", sr)","metadata":{"trus